{
  "name": "@retailerapi/mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for retailerapi.com — exposes Walmart product data, price history, offers, sellers, and reviews as tools for AI agents (Claude Desktop, Claude Code, Cursor).",
  "license": "MIT",
  "author": "retailerapi",
  "homepage": "https://retailerapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/marketermatt/retailerapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/marketermatt/retailerapi-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "walmart",
    "retailerapi",
    "product-data",
    "price-history"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "retailerapi-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
