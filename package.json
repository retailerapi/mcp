{
  "name": "@retailerapi/mcp",
  "version": "0.3.0",
  "description": "Model Context Protocol server for retailerapi.com — unified product data across major US retailers (Walmart, Amazon, eBay, Target, Best Buy, Lowe's, Home Depot). Three tools for AI agents: product lookup (with Bucket-1 facts + computed marketplace fees + canonical-merged weight/dims), live offers, and seller profiles. Works with Claude Desktop, Claude Code, Cursor.",
  "license": "MIT",
  "author": "retailerapi",
  "homepage": "https://retailerapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/retailerapi/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/retailerapi/mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "cross-retailer",
    "product-api",
    "retailerapi",
    "product-data",
    "price-history",
    "upc-lookup",
    "ean-lookup",
    "barcode-lookup",
    "amazon",
    "walmart",
    "ebay",
    "target",
    "bestbuy",
    "lowes",
    "homedepot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "retailerapi-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
