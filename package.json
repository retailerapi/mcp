{
  "name": "@retailerapi/mcp",
  "version": "0.3.2",
  "description": "Model Context Protocol server for retailerapi.com — unified product data across major US retailers (Walmart, Amazon, eBay, Target, Best Buy, Lowe's, Home Depot) plus universal URL passthrough for every Shopify store and any retailer that ships Product JSON-LD. Submit a UPC/EAN/ASIN/item_id or any retailer PDP URL. Tools: lookup_product (with Bucket-1 facts + computed marketplace fees + weight/dims merged from the best retailer source) + get_offers (live marketplace sellers). Works with Claude Desktop, Claude Code, Cursor.",
  "license": "MIT",
  "author": "retailerapi",
  "homepage": "https://retailerapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/retailerapi/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/retailerapi/mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "cross-retailer",
    "product-api",
    "retailerapi",
    "product-data",
    "price-history",
    "upc-lookup",
    "ean-lookup",
    "barcode-lookup",
    "amazon",
    "walmart",
    "ebay",
    "target",
    "bestbuy",
    "lowes",
    "homedepot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "retailerapi-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
